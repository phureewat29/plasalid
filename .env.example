# Plasalid environment variables. Copy this file to `.env` and fill the values.

# ─── Provider selection ──────────────────────────────────────────────────────
# Which AI provider to use. Values: anthropic | openai | gemini | openai-compat.
# Default: anthropic.
PLASALID_PROVIDER=

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
# Required when PLASALID_PROVIDER=anthropic. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional. Default: claude-sonnet-4-6.
ANTHROPIC_MODEL=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required when PLASALID_PROVIDER=openai. Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Optional. Default: gpt-5.4-mini.
OPENAI_MODEL=

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Required when PLASALID_PROVIDER=gemini. Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Optional. Default: gemini-2.5-pro.
GEMINI_MODEL=

# ─── OpenAI-compatible (LM Studio, Ollama, vLLM, etc.) ───────────────────────
# Required when PLASALID_PROVIDER=openai-compat. Examples:
#   http://localhost:1234/v1     (LM Studio default)
#   http://localhost:11434/v1    (Ollama default)
OPENAI_COMPAT_BASE_URL=

# Optional. Many local servers ignore this; leave blank or set to a sentinel
# like "lm-studio".
OPENAI_COMPAT_API_KEY=

# Required. Model name as the server exposes it (e.g. qwen/qwen3-vl-7b).
# Pick a vision-capable model — the scanner ships rasterized PDF pages as
# images on this route.
OPENAI_COMPAT_MODEL=

# ─── Storage ─────────────────────────────────────────────────────────────────
# Optional. Passphrase used to encrypt the local SQLite database (AES-256).
# `plasalid setup` generates one if left blank.
PLASALID_DB_ENCRYPTION_KEY=

# Optional. Default: ~/.plasalid/db.sqlite
PLASALID_DB_PATH=

# Optional. Default: ~/.plasalid/data
PLASALID_DATA_DIR=
