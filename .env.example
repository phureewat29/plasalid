# Plasalid environment variables. Copy this file to `.env` and fill the values

# Required: your Anthropic API key (https://console.anthropic.com).
ANTHROPIC_API_KEY=

# Optional: AI model used.
# Default: claude-sonnet-4-6.
PLASALID_MODEL=

# Optional: passphrase used to encrypt the local SQLite database (AES-256).
# `plasalid setup` will generate one for you if left blank.
PLASALID_DB_ENCRYPTION_KEY=

# Optional: override the SQLite database path.
# Default: ~/.plasalid/db.sqlite
PLASALID_DB_PATH=

# Optional: override where Plasalid looks for PDFs to scan.
# Default: ~/.plasalid/data
PLASALID_DATA_DIR=

# Optional. Which AI provider to use. Values: anthropic | openai-compatible.
# Default: anthropic.
PLASALID_PROVIDER=

# Optional. Base URL for an OpenAI-compatible chat completions endpoint
# (Ollama, OpenAI, LM Studio, vLLM, ...). Examples:
#   http://localhost:11434/v1   (Ollama default)
#   https://api.openai.com/v1
OPENAI_COMPATIBLE_BASE_URL=

# Optional. API key for OPENAI_COMPATIBLE_BASE_URL. Many local servers ignore
# this; leave blank or set to a sentinel like "ollama".
OPENAI_COMPATIBLE_API_KEY=
