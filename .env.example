# Plasalid environment variables. Copy this file to `.env` and fill the values.

# Optional. Relocates the entire ~/.plasalid directory. Individual
# PLASALID_* overrides below still win for their own paths.
PLASALID_DIR=

# Optional. Passphrase used to encrypt the local SQLite database (AES-256).
# `plasalid config --generate-key` generates one if left blank.
PLASALID_DB_ENCRYPTION_KEY=

# Optional. Default: ~/.plasalid/db.sqlite
PLASALID_DB_PATH=

# Optional. Default: ~/.plasalid/data
PLASALID_DATA_DIR=

# Optional. Scratch space for decrypted/rasterized artifacts handed to external
# agent CLIs. Default: ~/.plasalid/cache
PLASALID_CACHE_DIR=
