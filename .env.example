# Plasalid environment variables. Copy this file to `.env` and fill in the
# values you want. `plasalid setup` will use ANTHROPIC_API_KEY and
# PLASALID_USER_NAME as pre-filled suggestions; the rest are read at runtime.

# Required: your Anthropic API key (https://console.anthropic.com).
ANTHROPIC_API_KEY=

# Optional: model used for scan / chat / reconcile. Default: claude-sonnet-4-6.
PLASALID_MODEL=

# Optional: passphrase used to encrypt the local SQLite database (AES-256).
# `plasalid setup` will generate one for you if left blank.
PLASALID_DB_ENCRYPTION_KEY=

# Optional: override the SQLite database path. Default: ~/.plasalid/db.sqlite
PLASALID_DB_PATH=

# Optional: override where Plasalid looks for PDFs to scan.
# Default: ~/.plasalid/data
PLASALID_DATA_DIR=

# Optional, setup-time only: pre-fills the "Your name" prompt during
# `plasalid setup`. Not read at runtime.
PLASALID_USER_NAME=
